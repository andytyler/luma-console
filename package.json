{
  "name": "luma-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "bun run db:migrate && bun build/index.js",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "bun test --preload ./tests/setup.ts",
    "test:unit": "bun test tests/unit --preload ./tests/setup.ts",
    "db:migrate": "bun run scripts/migrate.ts",
    "db:seed-admin": "bun run scripts/seed-admin.ts",
    "worker": "bun run scripts/worker.ts"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@lucide/svelte": "^1.14.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@sveltejs/adapter-node": "latest",
    "@sveltejs/kit": "latest",
    "@sveltejs/vite-plugin-svelte": "latest",
    "@tailwindcss/vite": "latest",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "postgres": "latest",
    "svelte": "latest",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "latest",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "latest",
    "shadcn-svelte": "^1.2.7",
    "svelte-check": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
